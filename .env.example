# DataForSEO API (Google Maps Live Advanced)
# Get your credentials at https://dataforseo.com/
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Supabase (Auth)
# Get your project URL and anon key from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe (Checkout)
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# サブスクリプション用 Price ID (例: price_xxx)
STRIPE_PRICE_ID_PRO=
# Webhook 署名検証用（Stripe Dashboard > Developers > Webhooks > シークレット）
STRIPE_WEBHOOK_SECRET=

# 決済後のリダイレクト先（例: https://your-app.vercel.app または http://localhost:3000）
NEXT_PUBLIC_BASE_URL=

# Supabase 管理者キー（Webhook で users 更新に使用。絶対にクライアントに露出させないこと）
SUPABASE_SERVICE_ROLE_KEY=
